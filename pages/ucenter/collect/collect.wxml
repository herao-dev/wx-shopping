<view class="container">
    <view class="no-collect">
        <view wx:for="{{CollectList}}" class="collect" bind:tap="goGoods" data-id="{{item.id}}">
            <image src="{{imgApi+item.main_img}}"/>
            <view class="text">
                <view>{{item.name}}</view>
                <view>￥{{item.price}}</view>
            </view>
        </view>
    </view>
</view>