<view class="container">
  <!-- 没有浏览足迹 -->
  <view class="no-footprint">
   
  </view>
  <!-- 足迹列表 -->
  <view class="footprint">
    <view wx:for="{{FootprintList}}">
        <view class="rq" wx:if="{{FootprintList[index-1].createTime!=item.createTime}}">{{item.createTime}}</view>
        <view class="no-footprint">
            <view class="sp" bind:tap="goGoods" data-id="{{item.id}}">
                 <image src="{{imgApi+item.main_img}}" />
                <view>
                     <view>{{item.name}}</view>
                     <view>￥{{item.price}}</view>
                </view>
            </view>    
        </view>
    </view>
  </view>
  <view class="deleteAll" bind:tap="deleteAll">删除全部足迹</view>
</view>