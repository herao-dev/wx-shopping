page {
  height: 100%;
  width: 100%;
  background: #f4f4f4;
}
.dfh{
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: red;
    color: white;
    height: 20px;
    width: 20px;
    border-radius: 10px;
    position: absolute;
    left: 200px;
    top: 210px;
}
.dfk{
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: red;
    color: white;
    height: 20px;
    width: 20px;
    border-radius: 10px;
    position: absolute;
    left: 90px;
    top: 210px;
}
.dsh{
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: red;
    color: white;
    height: 20px;
    width: 20px;
    border-radius: 10px;
