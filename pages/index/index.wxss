.search{
    display: flex;
    align-items: center;
    justify-items: center;
    background-color: white;
    width: 550px;
}
.search-input{
    background-color: #f2f2f2;
    padding: 5px;
    text-align: center;
    width: 350px;
    margin: 5px 15px;
    font-size: 14px;
}
.banner {
  width: 750rpx;
  height: 417rpx;
}
.m-menu{
    padding-top: 10px;
    padding-bottom: 10px;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-evenly;
    align-items: center;
    background-color: white;
}
.m-menu1{
    width: 55px;
    height: 60px;
    margin: 10px 21px;
    font-size: 14px;
    text-align: center;
}
.m-menu1 image{
    width: 38px;
    height: 38px;
}
.banner image {
  width: 100%;
  height: 417rpx;
}
.a-new{
    margin-top: 10px;
    background-color: white;
    display: flex;
    flex-wrap: wrap;  
    justify-content: space-evenly;
}
.a-new1{
    margin-bottom: 10px;
    padding-bottom: 10px;
    padding: 20px;
    background-color: rgb(133, 234, 241);
    font-size: 20px;
    text-align: center;
    width: 100%;
}
.a-new2{
    width: 180px;
    height: 220px;
    text-align: center;
}
.a-new2 image{
    width: 170px;
    height: 170px;
}.a-new3{
    color: red;
}
.a-section{
    padding-top: 20px;
    padding-bottom: 20px;
    background-color: white;
    font-size: 20px;
    text-align: center;
    width: 100%;
}
.a-popular{
    padding-top: 20px;
    padding-bottom: 20px;
    margin-top: 10px;
    width: 100%;
}
.a-popular1{
    padding: 5px;
    display: flex;
    align-items: center;
}
.a-popular1 image{
    width: 170px;
    height: 170px;
}
.a-popular2{
    text-align: left;
    color: red;
    font-weight: 700;
}
.a-popular3{
    margin-top: 20px;
    border-top: 1px solid #f2f2f2;
}