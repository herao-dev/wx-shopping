<view class="container">
  <view class="form-box">

    <view class="form-item">
      <input class="mobile" placeholder="手机号" />
      <image id="clear-mobile" class="clear" src="/static/images/clear_input.png"></image>
    </view>

    <view class="form-item-code">
      <view class="form-item code-item">
        <input class="code" placeholder="验证码" />
        <image class="clear" id="clear-code" src="/static/images/clear_input.png"></image>
      </view>
      <view class="code-btn">获取验证码</view>
    </view>

    <view class="form-item">
      <input class="password" password placeholder="密码" />
      <image class="clear" id="clear-password" src="/static/images/clear_input.png"></image>
    </view>

    <view class="form-item">
      <input class="password" password placeholder="确认密码" />
      <image class="clear" id="clear-confirm-password" src="/static/images/clear_input.png"></image>
    </view>

    <button type="default" class="reset-btn">密码重置</button>

  </view>
</view>