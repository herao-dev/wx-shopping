<view class="container">
  <!-- 商品图片轮播 -->
  <swiper class="goodsimgs" indicator-dots="{{true}}" autoplay="{{true}}" interval="2000">
    <swiper-item wx:for="{{GoodsDetail.ProductImgList}}" >
        <image src="{{imgApi+item.imgUrl}}"/>
    </swiper-item>
  </swiper>
  <!-- 分享 -->
  <view class='goods_name'>
    {{GoodsDetail.ProductList[0].name}}
  </view>
  <!-- 商品信息 -->
  <view class="goods-info">
   <view class="jg yj">原价：￥{{GoodsDetail.ProductList[0].shopPrice}}</view> 
   <view class="jg"> 现价：￥{{GoodsDetail.ProductList[0].price}}</view>
  </view>
<view style="background-color: white;" bind:tap="switchAttrPop">
    <view class="comments">
        <view style="font-size: 18px;">规格数量选择</view> 
        <image src="/static/images/address_right.png"/>
    </view>
</view>
  <view class="detail" >
    {{GoodsDetail.ProductList[0].textEditor}}
  </view>
  <!-- 常见问题 -->
  <view class="common-problem">
    
  </view>
</view>
<!-- 规格选择界面 -->
<view class="attr-pop-box" hidden="{{!openAttr}}">
  <view class="attr-pop">
    <view class="close" bind:tap="closeAttr" >
        <image class="icon" src="/static/images/icon_close.png"></image>
    </view>
    <view class="img-info">
      <image class="img" src="{{imgApi+GoodsDetail.ProductImgList[2].imgUrl}}"></image>
      <view class="info">
        <view class="c">
          <view class="p">价格：￥{{GoodsDetail.ProductList[0].price}}</view>
          <view class="a" wx:if="{{box[0].ds==-1 && box[1].ds==-1}}">
            请选择规格数量</view>
          <view class="a" wx:if="{{box[0].ds!=-1 || box[1].ds!=-1}}">{{GoodsDetail.SpecsListTwo[box[0].ds].name}} {{GoodsDetail.SpecsListTwo[box[1].ds].name}}</view>
        </view>
      </view>
    </view>


    <!-- 规格列表 -->
    <view class="spec-con">
      <view  wx:for="{{GoodsDetail.SpecsListOne}}" wx:for-item="id" wx:for-index="a">
        <view class="spec-con1">{{id.name}}</view>
        <view style="display: flex; margin-bottom: 15px;">
            <view class="spec-con2 {{ box[a].ds==index ?  'active' : ''}}" bind:tap="active" wx:for="{{GoodsDetail.SpecsListTwo}}" wx:if="{{id.id==item.fatherId}}" data-index="{{index}}"  data-a="{{a}}">
                {{item.name}}
            </view>
        </view>
      </view>



        <view></view>
      <!-- 数量 -->
      <view class="number-item">
        <view class="number-text">数量</view>
        <view class="number">
            <view class="kk jian" bind:tap="jian">-</view>
            <input class="sl"  model:value="{{num}}"/>
            <view class="kk jia" bind:tap="jia">+</view>
        </view>
      </view>


    </view>
  </view>
</view>

<!-- 底部按钮 -->
<view class="bottom-btn">
    <view class="k" bind:tap="addCollectOrNot">
        <image class="sc" src="/static/images/icon_collect.png" />
        <image class="sc-1" wx:if="{{userHasCollect==0}}" src="/static/images/icon_collect_checked.png" />
    </view>
    <view class="k" >
        <image class="gwc" src="/static/images/ic_menu_shoping_nor.png" />
    </view>
    <view class="jrgwc" bind:tap="addToCart">
        加入购物车
    </view>
    <view class="gm" >
        立即购买
    </view>
</view>